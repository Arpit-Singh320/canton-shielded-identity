module Shielded.Test.IdentityTest where

import Daml.Script
import Shielded.Identity
import DA.Date as Date
import DA.Time (getTime)

-- | Encapsulates all identity-related tests.
identityTests : Script ()
identityTests = script do
  test_happy_path
  test_revocation_fails_verification
  test_expired_credential_fails_verification

-- | Tests the successful lifecycle of issuing a credential and then presenting it for verification.
test_happy_path : Script ()
test_happy_path = script do
  -- 1. Setup parties
  issuerBank <- allocatePartyWithHint "IssuerBank" (PartyIdHint "issuer-bank")
  userHolder <- allocatePartyWithHint "UserHolder" (PartyIdHint "user-holder")
  dappVerifier <- allocatePartyWithHint "DappVerifier" (PartyIdHint "dapp-verifier")
  debug "Parties allocated for happy path test."

  -- 2. Issuer establishes its role to issue credentials.
  issuerRoleCid <- submit issuerBank do
    createCmd IssuerRole with issuer = issuerBank

  -- 3. Issuer issues a valid, non-expired credential to the user.
  now <- getTime
  let expiry = Date.addDays (Date.toDateUTC now) 365 -- Expires in one year
  credentialCid <- submit issuerBank do
    exerciseCmd issuerRoleCid IssueCredential with
      holder = userHolder
      expiryDate = expiry
      personalDataHash = "hash-of-personal-data-123"
  debug $ "Credential issued to " <> show userHolder

  -- 4. A verifier (e.g., a dApp) requests KYC verification from the user.
  requestCid <- submit dappVerifier do
    createCmd VerificationRequest with
      verifier = dappVerifier
      holder = userHolder
      purpose = "Onboarding to Trading Platform"
  debug $ "Verification request created by " <> show dappVerifier

  -- 5. The user presents their credential to satisfy the request.
  verifiedCid <- submit userHolder do
    exerciseCmd requestCid PresentCredential with
      credentialCid = credentialCid
  debug "User presented credential."

  -- 6. Assert that a 'VerifiedCredential' contract was created and is visible
  --    to both the verifier and the holder.
  Some verifiedContractByHolder <- queryContractId userHolder verifiedCid
  verifiedContractByHolder.verifier === dappVerifier
  verifiedContractByHolder.holder === userHolder

  Some verifiedContractByVerifier <- queryContractId dappVerifier verifiedCid
  verifiedContractByVerifier.verifier === dappVerifier

  debug "Happy path test successful: Credential issued and verified."

-- | Tests that a revoked credential cannot be used for verification.
test_revocation_fails_verification : Script ()
test_revocation_fails_verification = script do
  -- 1. Setup parties
  issuerBank <- allocatePartyWithHint "IssuerBankRevoke" (PartyIdHint "issuer-bank-revoke")
  userHolder <- allocatePartyWithHint "UserHolderRevoke" (PartyIdHint "user-holder-revoke")
  dappVerifier <- allocatePartyWithHint "DappVerifierRevoke" (PartyIdHint "dapp-verifier-revoke")
  debug "Parties allocated for revocation test."

  -- 2. Issue a credential as in the happy path.
  issuerRoleCid <- submit issuerBank do createCmd IssuerRole with issuer = issuerBank
  now <- getTime
  let expiry = Date.addDays (Date.toDateUTC now) 365
  credentialCid <- submit issuerBank do
    exerciseCmd issuerRoleCid IssueCredential with
      holder = userHolder, expiryDate = expiry, personalDataHash = "hash-456"
  debug "Credential issued for revocation test."

  -- 3. The issuer revokes the credential.
  submit issuerBank do
    exerciseCmd credentialCid RevokeCredential
  debug "Credential has been revoked by the issuer."

  -- 4. The verifier requests verification.
  requestCid <- submit dappVerifier do
    createCmd VerificationRequest with
      verifier = dappVerifier, holder = userHolder, purpose = "Accessing revoked service"

  -- 5. The user attempts to present the now-revoked credential. This must fail
  --    because the contract `credentialCid` has been archived.
  submitMustFail userHolder do
    exerciseCmd requestCid PresentCredential with
      credentialCid = credentialCid
  debug "Revocation test successful: Verification correctly failed for a revoked credential."

-- | Tests that an expired credential cannot be used for verification.
test_expired_credential_fails_verification : Script ()
test_expired_credential_fails_verification = script do
  -- 1. Setup parties
  issuerBank <- allocatePartyWithHint "IssuerBankExpired" (PartyIdHint "issuer-bank-expired")
  userHolder <- allocatePartyWithHint "UserHolderExpired" (PartyIdHint "user-holder-expired")
  dappVerifier <- allocatePartyWithHint "DappVerifierExpired" (PartyIdHint "dapp-verifier-expired")
  debug "Parties allocated for expiration test."

  -- 2. Issuer issues a credential that has already expired.
  issuerRoleCid <- submit issuerBank do createCmd IssuerRole with issuer = issuerBank
  now <- getTime
  let yesterday = Date.addDays (Date.toDateUTC now) (-1)
  credentialCid <- submit issuerBank do
    exerciseCmd issuerRoleCid IssueCredential with
      holder = userHolder
      expiryDate = yesterday
      personalDataHash = "hash-of-personal-data-789"
  debug "Expired credential issued."

  -- 3. Verifier requests verification.
  requestCid <- submit dappVerifier do
    createCmd VerificationRequest with
      verifier = dappVerifier, holder = userHolder, purpose = "Age verification with old ID"

  -- 4. The user attempts to present the expired credential. This must fail because the
  --    `PresentCredential` choice logic checks the expiry date.
  submitMustFail userHolder do
    exerciseCmd requestCid PresentCredential with
      credentialCid = credentialCid
  debug "Expiration test successful: Verification correctly failed for an expired credential."